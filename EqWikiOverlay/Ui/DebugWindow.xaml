<Window x:Class="EqWikiOverlay.Ui.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EQ Wiki Overlay — OCR Debug" Width="640" Height="720"
        Background="#FF15171F" Topmost="True" ShowInTaskbar="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="PICKED: " Foreground="#FF8A8FA3" FontFamily="Consolas" FontSize="14" />
            <TextBlock x:Name="PickedText" Text="—" Foreground="#FFF4C542" FontFamily="Consolas"
                       FontSize="14" FontWeight="Bold" />
            <TextBlock x:Name="PassText" Margin="16,0,0,0" Foreground="#FF7FB2FF"
                       FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="ResolvedText" Text="" Foreground="#FF9BE29B"
                   FontFamily="Consolas" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap" />

        <Border Grid.Row="2" BorderBrush="#FF3D4152" BorderThickness="1" Margin="0,0,0,8"
                MaxHeight="260" HorizontalAlignment="Left">
            <Image x:Name="CaptureImage" Stretch="None" />
        </Border>

        <Border Grid.Row="3" BorderBrush="#FF3D4152" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="RawText" IsReadOnly="True" TextWrapping="NoWrap"
                         Background="Transparent" Foreground="#FFDDE1EC" BorderThickness="0"
                         FontFamily="Consolas" FontSize="12" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
